#!/bin/sh
# .githooks/post-checkout
# Runs after every branch switch to keep the project tree and
# network remotes in sync with the current src/ structure.
#
# Intentionally does NOT run wally install or type generation —
# those are slow and require explicit action when packages change.
# 
# chmod +x .githooks/post-checkout
# git add .githooks/post-checkout
# git update-index --chmod=+x .githooks/post-checkout
# git commit -m "fix: populate post-checkout hook"
#
# Installed automatically by setup.sh via:
#   git config core.hooksPath .githooks

# $3 is 1 for branch checkout, 0 for file checkout — only run on branch switch
if [ "$3" != "1" ]; then
    exit 0
fi

cd "$(git rev-parse --show-toplevel)" || exit 1

echo ""
echo "▶ post-checkout: updating project tree and remotes..."
echo ""

# -- Remotes -----------------------------------------------
if ! command -v zap >/dev/null 2>&1; then
    echo "⚠ zap not found — skipping remote processing"
elif [ ! -f "scripts/process-remotes.sh" ]; then
    echo "⚠ scripts/process-remotes.sh not found — skipping remote processing"
else
    if sh scripts/process-remotes.sh; then
        echo "✓ Remotes processed"
    else
        echo "✗ Remote processing failed"
    fi
fi

# -- Project Tree -----------------------------------------------
if ! command -v node >/dev/null 2>&1; then
    echo "⚠ node not found — skipping tree regeneration"
elif [ ! -f "scripts/generateRojoTree.js" ]; then
    echo "⚠ scripts/generateRojoTree.js not found — skipping tree regeneration"
else
    if node scripts/generateRojoTree.js; then
        echo "✓ default.project.json updated"
    else
        echo "✗ Tree regeneration failed"
    fi
fi

echo ""
