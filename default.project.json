{
  "name": "BaseRobloxFramework",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared",
        "Services": {
          "$path": "src/services/Shared"
        }
      },

      "UI": {
        "$path": "src/ui"
      },

      "Packages": {
        "$path": "Packages"
      }
    },

    "ServerScriptService": {
      "Classes": {
        "$path": "src/server/Classes"
      },

      "Services": {
        "$path": "src/services/Server"
      },
      
      "ServerPackages": {
        "$path": "ServerPackages"
      },

      "ServerInitializer": {
        "$path": "src/init/Server.server.luau"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "ClientInitializer": {
          "$path": "src/init/Client.client.luau"
        }
      }
    }

  }
}